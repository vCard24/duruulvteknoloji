{
  "title": "Mission & Vision | Yiğit Çelik Kapı",
  "description": "Our goals and outlook for the future",
  "heroTitle": "Mission & vision",
  "heroLead": "Our goals and outlook for the future are the foundations that shape our company's present and tomorrow.",
  "bodyHtml": "<div class=\"corporate-body\">\n        <div class=\"container\">\n          <div class=\"corporate-content corporate-content--wide prose\">\n            <div class=\"page-block\">\n              <p class=\"page-kicker\">Our Future-Oriented Goals</p>\n              <p>\n                At Yiğit Çelik Kapı, we place customer satisfaction at the forefront and aim for continuous improvement,\n                production to high quality standards and a leading position in the industry.\n                Our mission and vision are the foundations that shape our company's present and future.\n              </p>\n            </div>\n            <div class=\"page-block\">\n              <div class=\"corporate-mission-panel\">\n                <p class=\"corporate-mission-panel__kicker\">\n                  <span class=\"corporate-mission-panel__kicker-line\" aria-hidden=\"true\"></span>\n                  OUR MISSION\n                </p>\n                <h2 class=\"corporate-mission-panel__title\">To lead in security and quality</h2>\n                <p>\n                  Guided by innovative and ethical working principles, we place the security of our customers and their families\n                  at the forefront as one of the industry's leading brands. Through our product range, high quality standards\n                  and customer-focused service, we continuously follow innovations and technological developments\n                  and make it our mission to deliver the best service at all times.\n                </p>\n                <ul class=\"corporate-checklist\">\n                  <li>Placing the security of our customers and their families first</li>\n                  <li>Acting with innovative and ethical working principles</li>\n                  <li>Meeting every need through a wide product range</li>\n                  <li>Manufacturing to high quality standards</li>\n                  <li>Working with a customer-focused service approach</li>\n                  <li>Following innovations and technological developments in the industry</li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <section class=\"section section--values-mosaic mv-vision-mosaic\" aria-labelledby=\"vision-mosaic-heading\">\n        <div class=\"container\">\n          <div class=\"values-mosaic-head\">\n            <p class=\"values-mosaic__kicker\">\n              <span class=\"values-mosaic__kicker-line\" aria-hidden=\"true\"></span>\n              OUR VISION\n            </p>\n            <h2 class=\"values-mosaic__title\" id=\"vision-mosaic-heading\">\n              <span class=\"values-mosaic__title-line\">Our outlook</span>\n              <span class=\"values-mosaic__title-line values-mosaic__title-line--accent\">for the future</span>\n            </h2>\n            <p class=\"values-mosaic__lead\">\n              At Yiğit Çelik Kapı, we are guided by customer satisfaction, continuous improvement, production to high quality standards,\n              teamwork and professional management. By closely following technological developments and acting with social responsibility,\n              we envision becoming one of the industry's leading organisations and sustaining our advantageous position.\n            </p>\n          </div>\n          <div class=\"values-grid values-grid--mosaic values-grid--mosaic-quad\">\n            <article class=\"value-card value-card--mosaic\">\n              <div class=\"value-card__icon\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\" />\n                  <path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\" />\n                  <path d=\"M4 22h16\" />\n                  <path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\" />\n                  <path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\" />\n                  <path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\" />\n                </svg>\n              </div>\n              <h3>Industry Leader</h3>\n              <p>To hold a leading position in the steel door industry</p>\n            </article>\n            <article class=\"value-card value-card--mosaic\">\n              <div class=\"value-card__icon\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <rect x=\"4\" y=\"4\" width=\"16\" height=\"16\" rx=\"2\" ry=\"2\" />\n                  <rect x=\"9\" y=\"9\" width=\"6\" height=\"6\" />\n                  <line x1=\"9\" y1=\"1\" x2=\"9\" y2=\"4\" />\n                  <line x1=\"15\" y1=\"1\" x2=\"15\" y2=\"4\" />\n                  <line x1=\"9\" y1=\"20\" x2=\"9\" y2=\"23\" />\n                  <line x1=\"15\" y1=\"20\" x2=\"15\" y2=\"23\" />\n                  <line x1=\"20\" y1=\"9\" x2=\"23\" y2=\"9\" />\n                  <line x1=\"20\" y1=\"14\" x2=\"23\" y2=\"14\" />\n                  <line x1=\"1\" y1=\"9\" x2=\"4\" y2=\"9\" />\n                  <line x1=\"1\" y1=\"14\" x2=\"4\" y2=\"14\" />\n                </svg>\n              </div>\n              <h3>Technological Development</h3>\n              <p>To deliver innovative solutions by closely following technological developments</p>\n            </article>\n            <article class=\"value-card value-card--mosaic\">\n              <div class=\"value-card__icon\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <polyline points=\"23 4 23 10 17 10\" />\n                  <polyline points=\"1 20 1 14 7 14\" />\n                  <path d=\"M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15\" />\n                </svg>\n              </div>\n              <h3>Sustainable Position</h3>\n              <p>To sustain our advantageous position in a lasting way</p>\n            </article>\n            <article class=\"value-card value-card--mosaic\">\n              <div class=\"value-card__icon\" aria-hidden=\"true\">\n                <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\">\n                  <path d=\"M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z\" />\n                </svg>\n              </div>\n              <h3>Social Responsibility</h3>\n              <p>To be an organisation that acts with social responsibility</p>\n            </article>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"mv-closing-band section--muted\" aria-label=\"Our commitment\">\n        <div class=\"container\">\n          <div class=\"corporate-mission-panel\">\n            <p class=\"corporate-mission-panel__kicker\">\n              <span class=\"corporate-mission-panel__kicker-line\" aria-hidden=\"true\"></span>\n              OUR COMMITMENT\n            </p>\n            <h2 class=\"corporate-mission-panel__title\">Determination to Achieve Our Goals</h2>\n            <p>\n              At Yiğit Çelik Kapı, we work resolutely with all our employees to achieve our mission and vision.\n              With our focus on quality, reliability and customer satisfaction, we look to the future with confidence.\n            </p>\n          </div>\n        </div>\n      </section>"
}
